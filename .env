# ===== CONFIGURACIÓN GENERAL =====
NODE_ENV=development
APP_NAME=Colegio Futuro Digital SOA

# ===== GATEWAY API =====
GATEWAY_PORT=3000
GATEWAY_HOST=localhost

# ===== SERVICIOS (PUERTOS) =====
ALUMNOS_SERVICE_PORT=3001
MATRICULA_SERVICE_PORT=3002
PROFESORES_SERVICE_PORT=3003
CURSOS_SERVICE_PORT=3004
PAGOS_SERVICE_PORT=3005
NOTIFICACIONES_SERVICE_PORT=3006
ASISTENCIA_SERVICE_PORT=3007

# ===== BASE DE DATOS =====
DB_TYPE=sqlite
DB_PATH=./database/colegio.db

# ===== AUTENTICACIÓN JWT =====
JWT_SECRET=clave_secreta_desarrollo_no_usar_en_produccion_2024
JWT_EXPIRE=7d

# ===== NOTIFICACIONES =====
EMAIL_SERVICE=gmail
EMAIL_USER=noreply@colegio.com
EMAIL_PASSWORD=tu_contraseña_app
EMAIL_FROM=noreply@colegiofuturodigital.com

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006,http://localhost:3007

# ===== DATOS DE PRUEBA =====
SEED_DATABASE=true
LOG_LEVEL=debug
