{
  "name": "colegio-futuro-digital-soa",
  "version": "1.0.0",
  "description": "Sistema de Gestión Académica - Arquitectura Orientada a Servicios",
  "main": "api-gateway/gateway.js",
  "scripts": {
    "start": "node api-gateway/gateway.js",
    "dev": "concurrently npm:gateway npm:alumnos npm:matricula npm:profesores npm:cursos npm:pagos npm:notificaciones npm:asistencia npm:calificaciones",
    "gateway": "nodemon api-gateway/gateway.js",
    "alumnos": "nodemon services/alumnos-service/server.js",
    "matricula": "nodemon services/matricula-service/server.js",
    "profesores": "nodemon services/profesores-service/server.js",
    "cursos": "nodemon services/cursos-service/server.js",
    "pagos": "nodemon services/pagos-service/server.js",
    "notificaciones": "nodemon services/notificaciones-service/server.js",
    "asistencia": "nodemon services/asistencia-service/server.js",
    "calificaciones": "nodemon services/calificaciones-service/server.js",
    "verify": "node verify-services.js",
    "test:api": "node test-api.js",
    "test": "jest --detectOpenHandles",
    "db:init": "node database/init.js",
    "db:verify": "node database/verify-data.js"
  },
  "keywords": [
    "SOA",
    "microservicios",
    "educación",
    "gestión académica"
  ],
  "author": "Edward Rivera, Naomi Caballero, Maria Celeste Cuba",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "nodemailer": "^6.9.1",
    "axios": "^1.3.4"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "concurrently": "^7.6.0",
    "jest": "^29.5.0",
    "supertest": "^6.3.3"
  }
}
