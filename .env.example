# ===== CONFIGURACIÓN GENERAL =====
NODE_ENV=development
APP_NAME=Colegio Futuro Digital SOA

# ===== GATEWAY API =====
GATEWAY_PORT=3000
GATEWAY_HOST=localhost

# ===== SERVICIOS (PUERTOS) =====
ALUMNOS_SERVICE_PORT=3001
MATRICULA_SERVICE_PORT=3002
PROFESORES_SERVICE_PORT=3003
CURSOS_SERVICE_PORT=3004
PAGOS_SERVICE_PORT=3005
NOTIFICACIONES_SERVICE_PORT=3006
ASISTENCIA_SERVICE_PORT=3007

# ===== BASE DE DATOS =====
DB_TYPE=sqlite
DB_PATH=./database/colegio.db

# PostgreSQL (si prefieres cambiar en futuro)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=colegio_futuro_digital

# ===== AUTENTICACIÓN JWT =====
JWT_SECRET=tu_clave_secreta_muy_segura_cambiar_en_produccion
JWT_EXPIRE=7d

# ===== NOTIFICACIONES =====
# Email
EMAIL_SERVICE=gmail
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_app
EMAIL_FROM=noreply@colegiofuturodigital.com

# SMS (Twilio) - opcional
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ===== INTEGRACIONES EXTERNAS =====
# Pasarela de Pagos (simulada en desarrollo)
PAYMENT_GATEWAY_API_KEY=sk_test_dummy_key
PAYMENT_GATEWAY_URL=https://api.payment-gateway.com

# ===== LOGGING =====
LOG_LEVEL=debug

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006,http://localhost:3007

# ===== DATOS DE PRUEBA =====
SEED_DATABASE=true
